# ─────────────────────────────────────────────
# E-Commerce Docker Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ─────────────────────────────────────────────

ASPNETCORE_ENVIRONMENT=Production

# Database
DB_PASSWORD=YourStrong@Passw0rd

# JWT
JWT_SECRET=E-Commerce-Super-Secret-Key-Min-32-Chars-Long!
JWT_ISSUER=E-Commerce-API
JWT_AUDIENCE=E-Commerce-Clients
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# Email (Gmail SMTP)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SENDER_NAME=E-Commerce App
EMAIL_SENDER_EMAIL=your-email@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Rate Limiting
RATE_LIMIT_AUTH=5
RATE_LIMIT_CATALOG=20
RATE_LIMIT_CHECKOUT=3
